    "isolated-vm": "^6.0.2",
    "mssql": "^12.2.1"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.0.0",
    "swagger-typescript-api": "^13.0.0",
